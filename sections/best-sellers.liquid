<section class="py-28 bg-[#faf9f7]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-16 gap-6 animate-fade-up">
      <div>
        <span class="text-sm font-semibold tracking-widest uppercase text-brand-gradient">
          Our Products
        </span>
        <h2 class="text-5xl font-bold text-gray-900 mt-3">{{ section.settings.heading }}</h2>
        <p class="text-gray-500 mt-3 max-w-md">{{ section.settings.subheading }}</p>
      </div>
      <a
        href="{{ section.settings.collection.url | default: '/collections/all' }}"
        class="inline-flex items-center gap-2 border-2 border-[#2F5D3A] text-[#2F5D3A] px-6 py-3 rounded-full font-semibold hover:bg-[#2F5D3A] hover:text-white transition-all whitespace-nowrap"
      >
        View All Products {% render 'icon-arrow', size: 16 %}
      </a>
    </div>

    <!-- Product grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {%- assign collection = section.settings.collection -%}
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: 4 -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="animate-pulse">
            <div class="aspect-square rounded-3xl bg-gray-200 mb-4"></div>
            <div class="h-4 bg-gray-200 rounded w-3/4 mb-2"></div>
            <div class="h-4 bg-gray-200 rounded w-1/3"></div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- Bottom banner -->
    <div
      class="mt-16 rounded-3xl overflow-hidden relative animate-fade-up"
      style="background: linear-gradient(135deg, #2F5D3A 0%, #1e3d26 100%)"
    >
      <div class="absolute inset-0 opacity-10">
        <img src="{{ 'hero-bg.png' | asset_url }}" alt="" class="object-cover w-full h-full">
      </div>
      <div class="relative px-8 py-10 sm:px-14 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <p class="text-white text-2xl font-bold">{{ section.settings.banner_heading }}</p>
          <p class="text-white/70 mt-1">{{ section.settings.banner_subheading }}</p>
        </div>
        <a
          href="{{ section.settings.banner_link | default: '/collections/all' }}"
          class="inline-flex items-center gap-2 text-white px-8 py-4 rounded-full font-semibold hover:opacity-90 transition-all whitespace-nowrap shadow-lg bg-brand-gradient"
        >
          Explore All {% render 'icon-arrow', size: 16 %}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Clean ingredients, bold flavours — products people keep coming back to."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Banner Heading",
      "default": "New to Millo?"
    },
    {
      "type": "textarea",
      "id": "banner_subheading",
      "label": "Banner Subheading",
      "default": "Try our starter pack — handpicked for first-timers."
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner CTA Link"
    }
  ]
}
{% endschema %}
