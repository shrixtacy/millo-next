<div class="py-24 bg-[#faf9f7] min-h-[50vh]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-12">Your Cart</h1>

    {% if cart.item_count == 0 %}
      <div class="text-center py-12 bg-white rounded-3xl shadow-sm border border-gray-100">
        <p class="text-gray-500 text-lg mb-6">Your cart is empty</p>
        <a href="/collections/all" class="inline-flex items-center gap-2 text-white px-8 py-4 rounded-full font-semibold bg-brand-gradient shadow-lg hover:opacity-90 transition-all">
          Browse Products
        </a>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post" class="space-y-6">
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 divide-y divide-gray-50 overflow-hidden">
          {% for item in cart.items %}
            <div class="flex flex-col sm:flex-row gap-6 p-6">
              <div class="relative w-24 h-24 rounded-2xl overflow-hidden bg-[#F5E6D3] flex-shrink-0">
                {% if item.image %}
                  <img src="{{ item.image | img_url: '200x200' }}" alt="{{ item.product.title }}" class="object-cover w-full h-full">
                {% endif %}
              </div>
              <div class="flex-1 min-w-0">
                <a href="{{ item.url }}" class="font-bold text-lg text-gray-900 hover:text-[#2F5D3A] transition-colors">{{ item.product.title }}</a>
                {% unless item.variant.title contains 'Default' %}
                  <p class="text-sm text-gray-500 mt-1">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="text-lg font-bold text-[#2F5D3A] mt-2">{{ item.final_price | money }}</p>
              </div>
              <div class="flex items-center gap-4">
                <div class="flex items-center gap-3 border border-gray-200 rounded-full px-2 py-1">
                  <button type="submit" name="updates[]" value="{{ item.quantity | minus: 1 }}" class="w-8 h-8 flex items-center justify-center hover:text-[#2F5D3A]">-</button>
                  <span class="w-6 text-center font-medium">{{ item.quantity }}</span>
                  <button type="submit" name="updates[]" value="{{ item.quantity | plus: 1 }}" class="w-8 h-8 flex items-center justify-center hover:text-[#2F5D3A]">+</button>
                </div>
                <a href="{{ item.url_to_remove }}" class="text-gray-400 hover:text-red-500 transition-colors">
                  Remove
                </a>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 flex flex-col items-end gap-4">
          <div class="flex justify-between w-full sm:max-w-xs text-xl font-bold">
            <span class="text-gray-600">Total</span>
            <span class="text-[#2F5D3A]">{{ cart.total_price | money }}</span>
          </div>
          <p class="text-gray-400 text-sm">Shipping & taxes calculated at checkout</p>
          <button type="submit" name="checkout" class="w-full sm:max-w-xs text-white py-4 rounded-xl font-semibold bg-brand-gradient shadow-lg hover:opacity-90 transition-all">
            Proceed to Checkout
          </button>
        </div>
      </form>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Main Cart",
  "settings": []
}
{% endschema %}
