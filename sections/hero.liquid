<section class="relative min-h-screen lg:min-h-screen flex items-start lg:items-center overflow-hidden bg-white">
  <!-- Background image -->
  <div class="absolute inset-0 w-full h-full opacity-[0.18] pointer-events-none">
    <img src="{{ 'hero-bg.png' | asset_url }}" alt="" class="object-cover w-full h-full" loading="eager">
  </div>

  <!-- Millet decoration -->
  <div class="absolute bottom-16 -left-16 w-52 h-auto pointer-events-none hidden lg:block" style="z-index: 15; transform: rotate(25deg); transform-origin: bottom left;">
    <img src="{{ 'hero-millet.png' | asset_url }}" alt="" class="w-full h-auto object-contain">
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#faf9f7] to-transparent"></div>

  <!-- Main content -->
  <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 lg:pt-24 lg:pb-16 pb-0 grid lg:grid-cols-2 gap-8 items-center">
    <!-- Text -->
    <div class="pb-4 lg:pb-0 animate-fade-up">
      <div class="mb-6">
        <span class="inline-block text-xs font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full mb-4 text-white bg-brand-gradient">
          {{ section.settings.badge_text }}
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-gray-900 leading-[1.1] mb-4">
        {{ section.settings.heading | replace: 'Modern Fuel', '<span class="text-brand-gradient">Modern Fuel.</span>' }}
      </h1>

      <p class="text-base lg:text-lg text-gray-500 max-w-md mb-6 leading-relaxed">
        {{ section.settings.subheading }}
      </p>

      <div class="flex flex-wrap gap-3">
        <a href="{{ section.settings.primary_cta_link }}"
          class="inline-flex items-center gap-2 text-white px-6 py-3 rounded-full font-semibold hover:opacity-90 transition-all hover:scale-105 shadow-lg text-sm lg:text-base lg:px-8 lg:py-4 bg-brand-gradient">
          {{ section.settings.primary_cta_label }}
          {% render 'icon-arrow', size: 16 %}
        </a>
        <a href="{{ section.settings.secondary_cta_link }}"
          class="inline-flex items-center gap-2 border border-gray-200 text-gray-700 px-6 py-3 rounded-full font-medium hover:bg-gray-50 transition-all text-sm lg:text-base lg:px-8 lg:py-4">
          {{ section.settings.secondary_cta_label }}
        </a>
      </div>

      <div class="flex gap-6 mt-6 pt-6 border-t border-gray-100">
        <div>
          <p class="text-xl lg:text-2xl font-bold text-gray-900">{{ section.settings.stat_1_value }}</p>
          <p class="text-xs lg:text-sm text-gray-400">{{ section.settings.stat_1_label }}</p>
        </div>
        <div>
          <p class="text-xl lg:text-2xl font-bold text-gray-900">{{ section.settings.stat_2_value }}</p>
          <p class="text-xs lg:text-sm text-gray-400">{{ section.settings.stat_2_label }}</p>
        </div>
        <div>
          <p class="text-xl lg:text-2xl font-bold text-gray-900">{{ section.settings.stat_3_value }}</p>
          <p class="text-xs lg:text-sm text-gray-400">{{ section.settings.stat_3_label }}</p>
        </div>
      </div>
    </div>

    <!-- Desktop product showcase -->
    <div class="relative h-[580px] hidden lg:flex items-end justify-end" style="z-index: 30;">
      <div class="relative w-full h-full" style="margin-right: -80px;">
        <div class="parallax-sattu absolute bottom-0 -right-8 w-[440px] h-auto drop-shadow-2xl transition-transform duration-300">
          <img src="{{ 'hero-sattu.png' | asset_url }}" alt="Millo Millet Sattu Power Mix" class="w-full h-auto object-contain">
        </div>
        <div class="parallax-namkin absolute bottom-0 right-52 w-[360px] h-auto drop-shadow-2xl transition-transform duration-300" style="transform: rotate(-18deg);">
          <img src="{{ 'hero-namkin.png' | asset_url }}" alt="Millo Millet Namkeen Classic Masala" class="w-full h-auto object-contain">
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile product showcase -->
  <div class="lg:hidden absolute bottom-0 left-0 right-0 flex items-end justify-center pointer-events-none" style="z-index: 30; height: 280px;">
    <div class="absolute bottom-0 right-2 w-56 h-auto drop-shadow-xl">
      <img src="{{ 'hero-sattu.png' | asset_url }}" alt="Millo Millet Sattu Power Mix" class="w-full h-auto object-contain">
    </div>
    <div class="absolute bottom-0 right-44 w-48 h-auto drop-shadow-xl" style="transform: rotate(-18deg);">
      <img src="{{ 'hero-namkin.png' | asset_url }}" alt="Millo Millet Namkeen Classic Masala" class="w-full h-auto object-contain">
    </div>
  </div>

  <!-- Gradient orange overlapping features -->
  <div class="absolute bottom-0 left-0 right-0 pointer-events-none w-full" style="z-index: 20; transform: translateY(40%);">
    <img src="{{ 'hero-gradient-orange.png' | asset_url }}" alt="" class="w-full object-cover object-top h-auto">
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "100% Natural · Made in India"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Ancient Grain.\nModern Fuel."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Healthy millet-based snacks crafted for everyday life. Clean ingredients, sustained energy, zero compromise."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary Button Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 Value",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "Natural"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 Value",
      "default": "0"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Preservatives"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 Value",
      "default": "12+"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Products"
    }
  ]
}
{% endschema %}
