<div class="min-h-[30vh] bg-[#faf9f7] pt-24 pb-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-12 animate-fade-up">
      <span class="text-[#E4572E] text-sm font-semibold tracking-widest uppercase">
        {{ section.settings.subheading }}
      </span>
      <h1 class="text-4xl font-bold text-gray-900 mt-2">{{ collection.title | default: section.settings.heading }}</h1>
      <p class="text-gray-500 mt-3 max-w-xl">
        {{ collection.description | default: section.settings.description }}
      </p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "All Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback Heading",
      "default": "Shop Millo"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Fallback Description",
      "default": "Every product is crafted with clean ingredients, no preservatives, and a commitment to your health."
    }
  ]
}
{% endschema %}
