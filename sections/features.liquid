<section class="relative py-28 bg-white" style="z-index: 10;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-2xl mb-16 animate-fade-up">
      <span class="text-sm font-semibold tracking-widest uppercase text-brand-gradient">
        {{ section.settings.subheading }}
      </span>
      <h2 class="text-5xl font-bold text-gray-900 mt-3 leading-tight">
        {{ section.settings.heading }}
      </h2>
      <p class="text-gray-500 mt-4 text-lg leading-relaxed">
        {{ section.settings.description }}
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {%- for block in section.blocks -%}
        <div class="relative rounded-3xl p-8 overflow-hidden flex flex-col justify-between min-h-[280px] shadow-sm hover:shadow-xl transition-all duration-300 {{ block.settings.bg_color_class }}" style="background-color: {{ block.settings.bg_color }};">
          
          {%- if block.settings.image != blank -%}
            <div class="absolute -bottom-4 -right-4 w-36 h-36 opacity-20 pointer-events-none">
              <img src="{{ block.settings.image | image_url: width: 200 }}" alt="" class="object-contain w-full h-full">
            </div>
          {%- elsif block.settings.asset_image != blank -%}
            <div class="absolute -bottom-4 -right-4 w-36 h-36 opacity-20 pointer-events-none">
              <img src="{{ block.settings.asset_image | asset_url }}" alt="" class="object-contain w-full h-full">
            </div>
          {%- endif -%}

          <div>
            <p class="text-5xl font-bold mb-4 {% if block.settings.use_gradient_stat %}text-brand-gradient{% else %}text-white{% endif %}" style="{% unless block.settings.use_gradient_stat %}color: {{ block.settings.text_color }};{% endunless %}">
              {{ block.settings.stat }}
            </p>
            <h3 class="text-xl font-bold mb-2" style="color: {{ block.settings.text_color }};">{{ block.settings.title }}</h3>
            <p class="text-sm leading-relaxed" style="color: {{ block.settings.sub_text_color }};">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Small Subheading",
      "default": "Why Millo"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Main Heading",
      "default": "Goodness in every grain."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every Millo product is crafted with intention — clean ingredients, real nutrition, zero compromise."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "text",
          "id": "stat",
          "label": "Stat",
          "default": "8g+"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "High Fiber"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Millet is naturally rich in dietary fiber, supporting gut health and keeping you full longer."
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#2F5D3A"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "sub_text_color",
          "label": "Sub-text Color",
          "default": "#ffffff"
        },
        {
          "type": "checkbox",
          "id": "use_gradient_stat",
          "label": "Use Gradient for Stat",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Overlay Product Image"
        },
        {
          "type": "text",
          "id": "asset_image",
          "label": "Or use Asset image filename (e.g. product-sattu.png)"
        }
      ]
    }
  ]
}
{% endschema %}
