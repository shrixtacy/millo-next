<section id="about-preview" class="py-28 bg-[#faf9f7] overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Top label -->
    <div class="text-center mb-20 animate-fade-up">
      <span class="text-sm font-semibold tracking-widest uppercase text-brand-gradient">
        Our Story
      </span>
      <h2 class="text-5xl font-bold text-gray-900 mt-3">
        {{ section.settings.heading }}
      </h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 items-stretch">
      <!-- Left — image stack -->
      <div class="relative animate-fade-in">
        <div class="relative h-[560px] rounded-3xl overflow-hidden">
          {%- if section.settings.main_image != blank -%}
            <img 
              src="{{ section.settings.main_image | image_url: width: 1000 }}" 
              alt="{{ section.settings.image_alt }}" 
              class="object-cover w-full h-full"
              loading="lazy"
            >
          {%- else -%}
            <img 
              src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=900&q=80" 
              alt="Millet farming fields in Odisha" 
              class="object-cover w-full h-full"
              loading="lazy"
            >
          {%- endif -%}
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(47,93,58,0.7) 0%, transparent 60%);"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <p class="text-white/70 text-sm uppercase tracking-widest mb-1">Our Mission</p>
            <p class="text-white text-xl font-bold leading-snug">
              {{ section.settings.mission_text }}
            </p>
          </div>
        </div>

        <!-- Floating stat card -->
        <div class="absolute -top-6 -right-6 bg-white rounded-2xl shadow-2xl p-6 w-44">
          <p class="text-4xl font-bold text-[#2F5D3A]">{{ section.settings.founded_year }}</p>
          <p class="text-sm text-gray-500 mt-1">Founded by Nutriswift Foods</p>
        </div>

        <!-- Product image overlay -->
        <div class="absolute -bottom-6 -right-6 w-36 h-36 rounded-2xl overflow-hidden shadow-2xl border-4 border-white">
          <img src="{{ 'product-sattu.png' | asset_url }}" alt="Millo Sattu" class="object-contain w-full h-full bg-[#F5E6D3]">
        </div>
      </div>

      <!-- Right — content -->
      <div class="flex flex-col justify-center pl-0 lg:pl-8 animate-fade-up">
        <div class="space-y-5 text-gray-600 leading-relaxed text-lg mb-10">
          {{ section.settings.content }}
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-4 mb-10">
          <div>
            <div class="bg-white rounded-2xl p-5 text-center shadow-sm border border-gray-100">
              <p class="text-2xl font-bold text-[#2F5D3A]">{{ section.settings.stat_1_val }}</p>
              <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-wide">{{ section.settings.stat_1_label }}</p>
            </div>
          </div>
          <div>
            <div class="bg-white rounded-2xl p-5 text-center shadow-sm border border-gray-100">
              <p class="text-2xl font-bold text-[#2F5D3A]">{{ section.settings.stat_2_val }}</p>
              <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-wide">{{ section.settings.stat_2_label }}</p>
            </div>
          </div>
          <div>
            <div class="bg-white rounded-2xl p-5 text-center shadow-sm border border-gray-100">
              <p class="text-2xl font-bold text-[#2F5D3A]">{{ section.settings.stat_3_val }}</p>
              <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-wide">{{ section.settings.stat_3_label }}</p>
            </div>
          </div>
        </div>

        <!-- Trust pills -->
        <div class="flex flex-wrap gap-3 mb-10">
          {%- for block in section.blocks -%}
            <span class="bg-[#2F5D3A]/8 text-[#2F5D3A] text-sm font-medium px-4 py-2 rounded-full border border-[#2F5D3A]/20">
              {{ block.settings.tag }}
            </span>
          {%- endfor -%}
        </div>

        <a
          href="{{ section.settings.cta_link | default: '/pages/about' }}"
          class="inline-flex items-center gap-2 text-white px-8 py-4 rounded-full font-semibold w-fit hover:opacity-90 transition-all hover:scale-105 shadow-lg bg-brand-gradient"
        >
          Read Our Full Story
          {% render 'icon-arrow', size: 16 %}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Preview",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Rooted in tradition,\nbuilt for today."
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Millet farming fields in Odisha"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission Text",
      "default": "Take Odisha-grown millets from local farms to global shelves."
    },
    {
      "type": "text",
      "id": "founded_year",
      "label": "Founded Year",
      "default": "2025"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Millo is a millet-based food brand by <strong>Nutriswift Foods Private Limited</strong>, created to bring traditional Indian nutrition into modern lifestyles.</p><p>We believe the grains our ancestors thrived on deserve a place on today's table — not as a compromise, but as a celebration of clean, powerful nutrition.</p><p>Every product is sourced directly from Odisha's millet farmers, processed minimally, and delivered with full transparency.</p>"
    },
    {
      "type": "text",
      "id": "stat_1_val",
      "label": "Stat 1 Value",
      "default": "2025"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "Founded"
    },
    {
      "type": "text",
      "id": "stat_2_val",
      "label": "Stat 2 Value",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Natural"
    },
    {
      "type": "text",
      "id": "stat_3_val",
      "label": "Stat 3 Value",
      "default": "Odisha"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Sourced From"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "trust_tag",
      "name": "Trust Tag",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "default": "🌾 Farmer Sourced"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Preview",
      "blocks": [
        { "type": "trust_tag", "settings": { "tag": "🌾 Farmer Sourced" } },
        { "type": "trust_tag", "settings": { "tag": "🇮🇳 Made in India" } },
        { "type": "trust_tag", "settings": { "tag": "♻️ Sustainable" } },
        { "type": "trust_tag", "settings": { "tag": "✅ No Preservatives" } }
      ]
    }
  ]
}
{% endschema %}
