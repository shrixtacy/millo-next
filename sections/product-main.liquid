<section class="min-h-screen bg-[#faf9f7] pt-24 pb-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid lg:grid-cols-2 gap-16">
      
      <!-- Images -->
      <div class="animate-fade-in">
        <div class="relative aspect-square rounded-3xl overflow-hidden bg-[#F5E6D3] mb-4">
          <img
            id="ProductMainImage--{{ section.id }}"
            src="{{ product.featured_image | img_url: '1200x1200' }}"
            alt="{{ product.featured_image.alt | default: product.title }}"
            class="object-cover w-full h-full"
            loading="eager"
          >
          {%- if product.tags contains 'bestseller' -%}
            <span class="absolute top-4 left-4 bg-[#E4572E]/10 text-[#E4572E] text-xs font-semibold px-3 py-1 rounded-full">
              Bestseller
            </span>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="flex gap-3 overflow-x-auto pb-2">
            {%- for media in product.media -%}
              <button
                type="button"
                class="relative w-20 h-20 rounded-xl overflow-hidden border-2 transition-all {% if forloop.first %}border-[#2F5D3A]{% else %}border-transparent{% endif %}"
                onclick="document.getElementById('ProductMainImage--{{ section.id }}').src = '{{ media | img_url: '1200x1200' }}'; this.parentElement.querySelectorAll('button').forEach(b => b.classList.remove('border-[#2F5D3A]')); this.classList.add('border-[#2F5D3A]');"
              >
                <img src="{{ media | img_url: '200x200', crop: 'center' }}" alt="" class="object-cover w-full h-full">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Info -->
      <div class="flex flex-col animate-fade-up">
        <h1 class="text-4xl font-bold text-gray-900 mb-3">{{ product.title }}</h1>

        <p class="text-3xl font-bold text-[#2F5D3A] mb-6">
          {{ product.price | money }}
        </p>

        {%- form 'product', product, id: 'product-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          <!-- Variants -->
          {%- unless product.has_only_default_variant -%}
            <div class="mb-6">
              <p class="text-sm font-medium text-gray-700 mb-2">Size / Variant</p>
              <div class="flex flex-wrap gap-2">
                {%- for variant in product.variants -%}
                  <button
                    type="button"
                    data-id="{{ variant.id }}"
                    class="variant-btn px-4 py-2 rounded-lg border text-sm font-medium transition-all {% if variant.id == product.selected_or_first_available_variant.id %}active border-[#2F5D3A] bg-[#2F5D3A] text-white{% else %}border-gray-200 text-gray-700 hover:border-[#2F5D3A]{% endif %}"
                  >
                    {{ variant.title }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endunless -%}

          <!-- Quantity -->
          <div class="mb-8">
            <p class="text-sm font-medium text-gray-700 mb-2">Quantity</p>
            <div class="flex items-center gap-3">
              <button
                type="button"
                class="quantity-btn w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center hover:border-[#2F5D3A] transition-colors"
                data-action="minus"
              >
                -
              </button>
              <input type="number" name="quantity" value="1" min="1" class="text-lg font-semibold w-8 text-center border-none bg-transparent">
              <button
                type="button"
                class="quantity-btn w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center hover:border-[#2F5D3A] transition-colors"
                data-action="plus"
              >
                +
              </button>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <button
              type="submit"
              class="flex-1 flex items-center justify-center gap-2 border-2 border-[#2F5D3A] text-[#2F5D3A] py-4 rounded-xl font-semibold hover:bg-[#2F5D3A] hover:text-white transition-all"
            >
              {% render 'icon-cart', size: 18 %}
              Add to Cart
            </button>
            {{ form | payment_button }}
          </div>
        {%- endform -%}

        <!-- Trust badges -->
        <div class="grid grid-cols-2 gap-3 mb-8">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_badge' -%}
              <div class="flex items-center gap-2 bg-white border border-gray-100 rounded-xl px-4 py-3">
                <span class="text-[#2F5D3A]">{{ block.settings.icon }}</span>
                <span class="text-sm text-gray-700 font-medium">{{ block.settings.label }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <!-- Description / Benefits -->
        <div class="border-t border-gray-100 pt-6">
          <h3 class="font-bold text-gray-900 mb-4">About this product</h3>
          <div class="prose prose-sm text-gray-600 leading-relaxed">
            {{ product.description }}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Main",
  "settings": [],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "100% Natural"
        },
        {
          "type": "textarea",
          "id": "icon",
          "label": "Icon SVG / Emoji",
          "default": "🌾"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Main",
      "blocks": [
        { "type": "trust_badge", "settings": { "label": "100% Natural", "icon": "🌿" } },
        { "type": "trust_badge", "settings": { "label": "No Preservatives", "icon": "🛡️" } },
        { "type": "trust_badge", "settings": { "label": "High Fiber", "icon": "⚡" } },
        { "type": "trust_badge", "settings": { "label": "FSSAI Certified", "icon": "✅" } }
      ]
    }
  ]
}
{% endschema %}
