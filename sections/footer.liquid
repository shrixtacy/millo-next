<footer class="bg-[#111] text-white py-16">
  <!-- Top CTA strip -->
  <div class="border-b border-white/10 mb-16 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-2xl font-bold">Ready to eat clean?</p>
        <p class="text-gray-400 mt-1">Explore our full range of millet-based products.</p>
      </div>
      <a
        href="/collections/all"
        class="inline-flex items-center gap-2 text-white px-8 py-4 rounded-full font-semibold hover:opacity-90 transition-all whitespace-nowrap shadow-lg bg-brand-gradient"
      >
        Shop Now {% render 'icon-arrow', size: 16 %}
      </a>
    </div>
  </div>

  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <!-- Brand col -->
      <div class="md:col-span-5">
        {%- if section.settings.footer_logo != blank -%}
          <img src="{{ section.settings.footer_logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="h-20 w-auto object-contain mb-5">
        {%- else -%}
          <img src="{{ 'millo-logo.png' | asset_url }}" alt="Millo" class="h-20 w-auto object-contain mb-5">
        {%- endif -%}
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs mb-6">
          Ancient grains for modern lives. Millet-based foods crafted with care by Nutriswift Foods Private Limited, Odisha.
        </p>
        <div class="flex gap-3">
          {%- if settings.social_instagram_link -%}
            <a href="{{ settings.social_instagram_link }}" class="social-icon">Instagram</a>
          {%- endif -%}
          {%- if settings.social_twitter_link -%}
            <a href="{{ settings.social_twitter_link }}" class="social-icon">Twitter</a>
          {%- endif -%}
        </div>
      </div>

      <!-- Links -->
      <div class="md:col-span-3">
        <h4 class="text-xs font-semibold text-white mb-5 uppercase tracking-widest">Quick Links</h4>
        <ul class="space-y-3">
          {%- for link in section.settings.menu.links -%}
            <li>
              <a href="{{ link.url }}" class="text-sm text-gray-400 hover:text-white transition-colors flex items-center gap-2 group">
                <span class="w-0 group-hover:w-3 h-px bg-[#ff914d] transition-all duration-300"></span>
                {{ link.title }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-4">
        <h4 class="text-xs font-semibold text-white mb-5 uppercase tracking-widest">Contact</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex items-start gap-2">
            <span class="mt-0.5">📧</span>
            <a href="mailto:{{ shop.email }}" class="hover:text-white transition-colors">{{ shop.email }}</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5">📞</span>
            <span>+91-8144301610 / +91-9668667078</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5">📍</span>
            <span>Rasulgarh, Khordha, Odisha — 751025</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-14 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-600">
        © {{ 'now' | date: "%Y" }} Millo by Nutriswift Foods Pvt. Ltd. · CIN: U46909OD2025PTC049760
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-xs text-gray-600 hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="text-xs text-gray-600 hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
