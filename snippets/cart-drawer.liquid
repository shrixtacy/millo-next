{%- comment -%}
  Replicates Next.js CartDrawer.tsx
{%- endcomment -%}

<div id="cart-backdrop" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[100] hidden"></div>
<div id="cart-drawer" class="fixed right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl flex flex-col z-[101] transition-transform duration-300 translate-x-full">
  <!-- Header -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <h2 class="text-lg font-bold font-heading text-[#2F5D3A]">
      Your Cart
    </h2>
    <button
      id="close-cart"
      type="button"
      class="p-2 rounded-full hover:bg-gray-100 transition-colors"
      aria-label="Close cart"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"></line><line x1="6" x2="18" y1="6" y2="18"></line></svg>
    </button>
  </div>

  <!-- Items -->
  <div id="cart-items" class="flex-1 overflow-y-auto px-6 py-4 space-y-4">
    {% if cart.item_count == 0 %}
      <div class="flex flex-col items-center justify-center h-full gap-4 text-center">
        {% render 'icon-cart', size: 48, color: 'gray-200' %}
        <p class="text-gray-500">Your cart is empty</p>
        <a
          href="/collections/all"
          class="text-sm font-medium text-[#2F5D3A] underline underline-offset-2"
        >
          Browse products
        </a>
      </div>
    {% else %}
      {% for item in cart.items %}
        <div class="flex gap-4 py-3 border-b border-gray-50">
          <div class="relative w-20 h-20 rounded-lg overflow-hidden bg-[#F5E6D3] flex-shrink-0">
            {% if item.image %}
              <img src="{{ item.image | img_url: '100x100' }}" alt="{{ item.product.title }}" class="object-cover w-full h-full">
            {% endif %}
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-sm text-gray-900 truncate">{{ item.product.title }}</p>
            {% unless item.variant.title contains 'Default' %}
              <p class="text-xs text-gray-500 mt-0.5">{{ item.variant.title }}</p>
            {% endunless %}
            <p class="text-sm font-semibold text-[#2F5D3A] mt-1">{{ item.price | money }}</p>
            <div class="flex items-center gap-2 mt-2">
              <button
                type="button"
                data-id="{{ item.key }}"
                data-quantity="{{ item.quantity | minus: 1 }}"
                class="cart-qty-btn w-6 h-6 rounded-full border border-gray-200 flex items-center justify-center hover:border-[#2F5D3A] transition-colors"
                onclick="updateCartItem('{{ item.key }}', {{ item.quantity | minus: 1 }})"
              >
                -
              </button>
              <span class="text-sm font-medium w-6 text-center">{{ item.quantity }}</span>
              <button
                type="button"
                data-id="{{ item.key }}"
                data-quantity="{{ item.quantity | plus: 1 }}"
                class="cart-qty-btn w-6 h-6 rounded-full border border-gray-200 flex items-center justify-center hover:border-[#2F5D3A] transition-colors"
                onclick="updateCartItem('{{ item.key }}', {{ item.quantity | plus: 1 }})"
              >
                +
              </button>
              <button
                type="button"
                class="ml-auto text-xs text-gray-400 hover:text-red-500 transition-colors"
                onclick="updateCartItem('{{ item.key }}', 0)"
              >
                Remove
              </button>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  <!-- Footer -->
  {% if cart.item_count > 0 %}
    <div class="px-6 py-5 border-t border-gray-100 space-y-4">
      <div class="flex justify-between items-center">
        <span class="text-gray-600">Subtotal</span>
        <span id="cart-drawer-subtotal" class="font-bold text-lg text-[#2F5D3A]">
          {{ cart.total_price | money }}
        </span>
      </div>
      <p class="text-xs text-gray-400">Shipping & taxes calculated at checkout</p>
      <form action="{{ routes.cart_url }}" method="post">
        <button
          type="submit"
          name="checkout"
          class="w-full text-white py-4 rounded-xl font-semibold hover:opacity-90 transition-all bg-brand-gradient"
        >
          Checkout
        </button>
      </form>
    </div>
  {% endif %}
</div>

<script>
  function updateCartItem(id, qty) {
    const data = {
      id: id,
      quantity: qty
    };

    fetch(window.routes.cart_change_url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(cart => {
      window.location.reload(); // Simple refresh for now
    })
    .catch(error => {
      console.error('Error updating cart:', error);
    });
  }

  function addToCart(id, qty = 1) {
    const data = {
      id: id,
      quantity: qty
    };

    fetch(window.routes.cart_add_url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(item => {
      window.location.reload(); // Simple refresh for now
    })
    .catch(error => {
      console.error('Error adding to cart:', error);
    });
  }
</script>
